# Gemini AI (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY="your-gemini-api-key"

# Vercel Blob (https://vercel.com/dashboard/stores)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"
